    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Hind Siliguri', sans-serif; scroll-behavior: smooth; background: #fef3c7; }
        .honey-gradient { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
        .section-hidden { display: none; }
        .sidebar-transition { transition: transform 0.3s ease-in-out; }
        
        /* Invoice Modal Styles */
        .invoice-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            overflow-y: auto;
        }
        
        .invoice-modal-content {
            background: white;
            margin: 30px auto;
            padding: 20px;
            border-radius: 20px;
            max-width: 90%;
            width: 800px;
            position: relative;
            animation: modalSlideIn 0.3s ease;
        }
        
        @keyframes modalSlideIn {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        .invoice-container {
            background: white;
            padding: 30px;
            border-radius: 16px;
            font-family: 'Hind Siliguri', sans-serif;
        }
        
        .invoice-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }
        
        .invoice-table th,
        .invoice-table td {
            border: 1px solid #e2e8f0;
            padding: 10px 12px;
        }
        
        .invoice-table th {
            background-color: #fffbeb;
            color: #92400e;
            font-weight: 700;
        }
        
        .close-modal {
            position: absolute;
            top: 15px;
            right: 25px;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            color: #666;
            transition: 0.3s;
        }
        
        .close-modal:hover {
            color: #d97706;
        }
        
        .download-btn {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            color: white;
            padding: 12px 28px;
            border: none;
            border-radius: 40px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            margin: 10px;
        }
        
        .download-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(217,119,6,0.3);
        }
        
        .btn-secondary {
            background: #6b7280;
        }
        
        .btn-secondary:hover {
            background: #4b5563;
        }
        
        .success-toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #10b981;
            color: white;
            padding: 12px 24px;
            border-radius: 50px;
            font-weight: bold;
            z-index: 1000;
            animation: slideUp 0.3s ease, fadeOut 0.5s ease 3s forwards;
        }
        
        @keyframes slideUp {
            from { bottom: 0; opacity: 0; }
            to { bottom: 30px; opacity: 1; }
        }
        
        @keyframes fadeOut {
            to { opacity: 0; visibility: hidden; }
        }
    </style>
</head>
