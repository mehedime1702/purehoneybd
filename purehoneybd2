    <script>
        // ========== DATA & STATE ==========
        let cart = [];
        let currentInvoiceHTML = '';
        
        const products = [
            { id: 1, name: 'সরিষা ফুলের মধু', price: 900, icon: '🍯' },
            { id: 2, name: 'কালোজিরা ফুলের মধু', price: 1200, icon: '🐝' },
            { id: 3, name: 'লিচু ফুলের মধু', price: 850, icon: '🌸' },
            { id: 4, name: 'মিশ্র ফুলের মধু', price: 1000, icon: '✨' }
        ];

        function renderProducts() {
            const grid = document.getElementById('products-grid');
            if(!grid) return;
            grid.innerHTML = '';
            products.forEach(p => {
                const card = document.createElement('div');
                card.className = 'bg-white rounded-3xl p-6 shadow-sm border border-amber-100 text-center hover:shadow-xl transition duration-300';
                card.innerHTML = `<div class="text-6xl mb-4">${p.icon}</div><h3 class="text-xl font-bold mb-2 text-amber-900">${p.name}</h3><p class="text-amber-600 font-bold text-2xl mb-6">${p.price}৳ /কেজি</p><button onclick="addToCart(${p.id})" class="w-full bg-amber-500 text-white py-3 rounded-2xl font-bold hover:bg-amber-600 shadow-md transition">কার্টে যোগ করুন</button>`;
                grid.appendChild(card);
            });
        }

        function updateCartUI() {
            const container = document.getElementById('cart-items');
            const cartCountSpan = document.getElementById('cart-count');
            if (!container) return;
            if (cart.length === 0) {
                container.innerHTML = '<div class="text-center mt-10 text-gray-400 py-10"><i class="fas fa-shopping-basket text-4xl mb-2"></i><p>আপনার ব্যাগ খালি</p></div>';
            } else {
                container.innerHTML = '';
            }
            let subtotal = 0;
            cart.forEach(item => {
                subtotal += (item.price * item.qty);
                const itemDiv = document.createElement('div');
                itemDiv.className = 'flex justify-between items-center bg-amber-50 p-4 rounded-2xl border border-amber-100';
                itemDiv.innerHTML = `<div><p class="font-bold text-amber-900">${item.name}</p><p class="text-amber-600 font-bold">${item.price * item.qty}৳</p></div><div class="flex items-center gap-3 bg-white px-3 py-1 rounded-full shadow-sm"><button onclick="changeQty(${item.id}, -1)" class="text-amber-600 font-bold px-2 text-xl">-</button><span class="font-bold min-w-[28px] text-center">${item.qty}</span><button onclick="changeQty(${item.id}, 1)" class="text-amber-600 font-bold px-2 text-xl">+</button></div>`;
                container.appendChild(itemDiv);
            });
            const delRadio = document.querySelector('input[name="del-charge"]:checked');
            const deliveryCharge = delRadio ? parseInt(delRadio.value) : 60;
            const totalAmount = subtotal + deliveryCharge;
            document.getElementById('total-price').innerText = totalAmount + " টাকা";
            const totalCount = cart.reduce((sum, i) => sum + i.qty, 0);
            if(cartCountSpan) cartCountSpan.innerText = totalCount;
        }

        function updateCart() { updateCartUI(); }
        
        function addToCart(id) {
            const product = products.find(p => p.id === id);
            if (!product) return;
            const existing = cart.find(i => i.id === id);
            if(existing) existing.qty += 1;
            else cart.push({ id: product.id, name: product.name, price: product.price, qty: 1 });
            updateCartUI();
            showToast('✅ কার্টে যুক্ত হয়েছে');
        }

        function changeQty(id, delta) {
            const itemIndex = cart.findIndex(i => i.id === id);
            if(itemIndex === -1) return;
            const item = cart[itemIndex];
            item.qty += delta;
            if(item.qty <= 0) cart.splice(itemIndex, 1);
            updateCartUI();
        }

        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'success-toast';
            toast.innerHTML = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if(sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        function showSection(id) {
            ['home-section', 'track-section', 'contact-section'].forEach(s => { const el = document.getElementById(s); if(el) el.classList.add('section-hidden'); });
            document.getElementById(id + '-section').classList.remove('section-hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleCart() { document.getElementById('cart-sidebar').classList.toggle('hidden'); updateCartUI(); }
        function openOrderModal() { if(cart.length === 0) { showToast("কার্ট খালি! পণ্য যুক্ত করুন।"); return; } document.getElementById('order-modal').classList.remove('hidden'); }
        function closeOrderModal() { document.getElementById('order-modal').classList.add('hidden'); }
        
        function trackOrder() {
            const trackId = document.getElementById('track-input').value.trim();
            const resultDiv = document.getElementById('track-result');
            if (!trackId) { resultDiv.innerText = "অর্ডার আইডি দিন"; return; }
            if(trackId.toUpperCase().startsWith('HB') && trackId.length >= 3) resultDiv.innerHTML = `✅ অর্ডার ${trackId} প্রক্রিয়াধীন। ২-৩ দিনের মধ্যে ডেলিভারি হবে।`;
            else resultDiv.innerHTML = `❌ "${trackId}" সঠিক অর্ডার আইডি নয়।`;
        }

        // ========== INVOICE GENERATION FUNCTION ==========
        function generateInvoiceHTML(orderData) {
            const { orderID, name, phone, address, subtotal, deliveryCharge, finalTotal, cartItems } = orderData;
            const today = new Date();
            const formattedDate = today.toLocaleDateString('bn-BD', { year: 'numeric', month: 'long', day: 'numeric' });
            
            let productsHTML = '';
            cartItems.forEach(item => {
                productsHTML += `
                    <tr>
                        <td style="padding: 10px 12px; border: 1px solid #e2e8f0;">🍯 ${item.name}</td>
                        <td style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: center;">${item.qty} কেজি</td>
                        <td style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: right;">${item.price.toLocaleString()} ৳</td>
                        <td style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: right; font-weight: 600;">${(item.price * item.qty).toLocaleString()} ৳</td>
                    </tr>
                `;
            });
            
            return `
                <div style="text-align: center; margin-bottom: 24px; border-bottom: 3px solid #f59e0b; padding-bottom: 16px;">
                    <h1 style="font-size: 32px; font-weight: 800; color: #d97706; margin: 0 0 8px 0;">PureHoneyBD</h1>
                    <p style="font-size: 16px; font-weight: 500; color: #92400e; margin: 0 0 4px 0;">১০০% খাঁটি মধুর বিশ্বস্ত প্রতিষ্ঠান</p>
                    <p style="font-size: 12px; color: #78350f;">📞 হেল্পলাইন: ০১৫২১২৪৩৮৮১ | 📧 mehedime1702@gmail.com | 📍 গুলশান-১, ঢাকা</p>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap;">
                    <div>
                        <h2 style="font-size: 20px; font-weight: 700; color: #92400e; background: #fffbeb; display: inline-block; padding: 6px 20px; border-radius: 30px; border: 1px solid #fcd34d;">📄 ডেলিভারি চালান / ইনভয়েস</h2>
                    </div>
                    <div style="background: #fef3c7; padding: 10px 18px; border-radius: 12px; text-align: right;">
                        <p style="font-size: 14px; margin: 2px 0;"><strong>অর্ডার আইডি:</strong> <span style="font-weight: 700; color: #d97706;">${orderID}</span></p>
                        <p style="font-size: 13px; margin: 2px 0;"><strong>তারিখ:</strong> ${formattedDate}</p>
                        <p style="font-size: 13px; margin: 2px 0;"><strong>পেমেন্ট:</strong> ক্যাশ অন ডেলিভারি</p>
                    </div>
                </div>

                <div style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); padding: 18px; border-radius: 16px; margin-bottom: 24px; border: 1px solid #fde68a;">
                    <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
                        <div style="flex: 1;">
                            <h3 style="font-size: 16px; font-weight: 700; color: #78350f; margin-bottom: 12px; border-left: 4px solid #f59e0b; padding-left: 10px;">👤 প্রাপকের তথ্য</h3>
                            <p style="font-size: 14px; margin: 6px 0;"><strong>নাম:</strong> ${name}</p>
                            <p style="font-size: 14px; margin: 6px 0;"><strong>মোবাইল:</strong> ${phone}</p>
                            <p style="font-size: 14px; margin: 6px 0;"><strong>ঠিকানা:</strong> ${address}</p>
                        </div>
                        <div style="flex: 1; text-align: right;">
                            <h3 style="font-size: 16px; font-weight: 700; color: #78350f; margin-bottom: 12px; border-left: 4px solid #f59e0b; padding-left: 10px;">🚚 ডেলিভারি তথ্য</h3>
                            <p style="font-size: 14px; margin: 6px 0;"><strong>পদ্ধতি:</strong> হোম ডেলিভারি</p>
                            <p style="font-size: 14px; margin: 6px 0;"><strong>প্রদান সময়:</strong> ২-৩ কর্মদিবস</p>
                        </div>
                    </div>
                </div>

                <table class="invoice-table" style="width: 100%; border-collapse: collapse; margin: 20px 0;">
                    <thead>
                        <tr style="background-color: #fffbeb; color: #92400e;">
                            <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: left; width: 50%;">পণ্যের বিবরণ</th>
                            <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: center; width: 20%;">পরিমাণ (কেজি)</th>
                            <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: right; width: 15%;">একক মূল্য</th>
                            <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: right; width: 15%;">মোট মূল্য</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${productsHTML}
                    </tbody>
                </table>

                <div style="display: flex; justify-content: flex-end; margin: 20px 0 30px 0;">
                    <div style="width: 280px; background: #fffbeb; padding: 18px 20px; border-radius: 16px; border: 1px solid #fed7aa;">
                        <div style="display: flex; justify-content: space-between; font-size: 15px; margin-bottom: 10px;">
                            <span>উপ-মোট:</span>
                            <span><strong>${subtotal.toLocaleString()}</strong> ৳</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 15px; margin-bottom: 12px; border-bottom: 2px dashed #fcd34d; padding-bottom: 10px;">
                            <span>ডেলিভারি চার্জ:</span>
                            <span><strong>${deliveryCharge}</strong> ৳</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 20px; font-weight: 800; color: #b45309; margin-top: 5px;">
                            <span>সর্বমোট বিল:</span>
                            <span>${finalTotal.toLocaleString()} ৳</span>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 35px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; border-top: 2px solid #fde68a; padding-top: 20px;">
                    <div style="font-size: 11px; color: #78350f;">
                        <p>✅ পণ্য গ্রহণের সময় ইনভয়েসটি চেক করে নিবেন।</p>
                        <p>⭐ ডেলিভারির সময় নগদ অর্থ প্রদান করুন। ধন্যবাদ!</p>
                    </div>
                    <div style="text-align: center;">
                        <div style="margin-bottom: 5px;">
                            <svg width="120" height="40" viewBox="0 0 120 40">
                                <path d="M10,30 Q30,15 50,25 Q70,35 90,20 Q110,5 115,15" stroke="#92400e" fill="none" stroke-width="1.5"/>
                                <text x="35" y="38" font-size="8" fill="#78350f">মেহেদী হাসান</text>
                            </svg>
                        </div>
                        <div style="border-top: 1px solid #92400e; padding-top: 4px; font-size: 11px; font-weight: 600; color: #78350f;">কর্তৃপক্ষের স্বাক্ষর</div>
                    </div>
                </div>
                <div style="text-align: center; margin-top: 20px; font-size: 10px; color: #d4a373; border-top: 1px solid #fef3c7; padding-top: 12px;">© ২০২৬ PureHoneyBD | ১০০% খাঁটি ও বিশুদ্ধ মধুর অঙ্গীকার</div>
            `;
        }

        // ========== SHOW INVOICE MODAL ==========
        function showInvoiceModal(orderData) {
            currentInvoiceHTML = generateInvoiceHTML(orderData);
            document.getElementById('invoice-display').innerHTML = currentInvoiceHTML;
            document.getElementById('invoice-modal').style.display = 'flex';
        }

        function closeInvoiceModal() {
            document.getElementById('invoice-modal').style.display = 'none';
        }

        // ========== DOWNLOAD AS JPG ==========
        async function downloadInvoiceAsJPG() {
            const invoiceElement = document.getElementById('invoice-display');
            
            // Show loading
            const downloadBtn = event.target;
            const originalText = downloadBtn.innerHTML;
            downloadBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> প্রস্তুত হচ্ছে...';
            downloadBtn.disabled = true;
            
            try {
                const canvas = await html2canvas(invoiceElement, {
                    scale: 3,
                    backgroundColor: '#ffffff',
                    logging: false,
                    useCORS: true
                });
                
                const image = canvas.toDataURL('image/jpeg', 1.0);
                const link = document.createElement('a');
                const orderId = document.querySelector('#invoice-display .invoice-container span')?.innerText || 'Invoice';
                link.download = `PureHoneyBD_Invoice_${Date.now()}.jpg`;
                link.href = image;
                link.click();
                
                showToast('📸 ইনভয়েস জেপিজি হিসেবে ডাউনলোড হয়েছে!');
            } catch (error) {
                console.error('Error:', error);
                showToast('❌ ডাউনলোড করতে সমস্যা হয়েছে। আবার চেষ্টা করুন।');
            } finally {
                downloadBtn.innerHTML = originalText;
                downloadBtn.disabled = false;
            }
        }

        // ========== ORDER SUBMIT HANDLER ==========
        document.getElementById('order-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            const name = document.getElementById('cust-name').value.trim();
            const phone = document.getElementById('cust-phone').value.trim();
            const address = document.getElementById('cust-address').value.trim();
            if(!name || !phone || !address) { showToast("নাম, মোবাইল ও ঠিকানা পূরণ করুন"); return; }
            if(cart.length === 0) { showToast("কার্ট খালি"); return; }
            
            const btn = document.getElementById('submit-btn');
            btn.disabled = true; btn.innerText = "অর্ডার হচ্ছে...";
            
            const orderID = "HB" + Math.floor(1000 + Math.random() * 9000);
            const delRadio = document.querySelector('input[name="del-charge"]:checked');
            const deliveryCharge = delRadio ? parseInt(delRadio.value) : 60;
            let subtotal = 0;
            cart.forEach(item => { subtotal += (item.price * item.qty); });
            const finalTotal = subtotal + deliveryCharge;
            
            const orderData = {
                orderID, name, phone, address, subtotal, deliveryCharge, finalTotal, cartItems: [...cart]
            };
            
            // Show invoice modal
            showInvoiceModal(orderData);
            
            // Reset cart and close modals
            cart = [];
            updateCartUI();
            closeOrderModal();
            document.getElementById('cart-sidebar').classList.add('hidden');
            document.getElementById('order-form').reset();
            
            showToast(`🎉 অর্ডার নিশ্চিত হয়েছে! (আইডি: ${orderID})`);
            
            btn.disabled = false; btn.innerText = "অর্ডার নিশ্চিত করুন";
        });

        // Initialize
        window.addEventListener('DOMContentLoaded', () => {
            renderProducts();
            updateCartUI();
            showSection('home');
            document.querySelectorAll('input[name="del-charge"]').forEach(r => r.addEventListener('change', () => updateCartUI()));
        });
        
        window.toggleSidebar = toggleSidebar; window.showSection = showSection; window.toggleCart = toggleCart;
        window.addToCart = addToCart; window.changeQty = changeQty; window.updateCart = updateCartUI;
        window.openOrderModal = openOrderModal; window.closeOrderModal = closeOrderModal; window.trackOrder = trackOrder;
        window.closeInvoiceModal = closeInvoiceModal; window.downloadInvoiceAsJPG = downloadInvoiceAsJPG;
    </script>
</body>
</html>
